# =================================================================
# AETHERIUS PROJECT ENVIRONMENT VARIABLES
# =================================================================
# Copy this file to .env and fill in your actual values.
#
# Architecture: a single conversational COORDINATOR plans and assigns tasks
# over WebSocket to one or more Bot Server Managers (BSM); each BSM spawns and
# relays to Bot Agents over local TCP. World state is persisted via MongoDB.
# =================================================================


# -----------------------------------------------------------
# SHARED (used by multiple services)
# -----------------------------------------------------------
# Google Gemini API key — required by the coordinator's LLM planner.
# Get one from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Minecraft server the agents connect to.
MC_HOST=localhost
MC_PORT=25565
# Must match the server version.
MC_VERSION=1.21.1

# Minecraft authentication mode for agents: offline | microsoft
MC_AUTH=offline
# Microsoft account email — only used when MC_AUTH=microsoft (online-mode servers).
# MC_USERNAME=you@example.com

# Optional shared secret for the cluster. When set, BSMs must present a matching
# token to register with the coordinator, and agents must present it to their BSM.
# Leave unset to DISABLE auth (fine for local dev).
# CLUSTER_AUTH_TOKEN=change-me-to-a-long-random-secret


# -----------------------------------------------------------
# WORLD STATE SERVICE
# -----------------------------------------------------------
# HTTP API port.
PORT=3000
# WebSocket port for real-time world-state updates.
WS_PORT=3001
# MongoDB connection string.
#   Local:  mongodb://localhost:27017/aetherius_world_state
#   Docker: mongodb://mongo:27017/aetherius_world_state
#   Atlas:  mongodb+srv://user:pass@cluster.mongodb.net/aetherius_world_state
MONGO_URI=mongodb://localhost:27017/aetherius_world_state


# -----------------------------------------------------------
# BOT SERVER MANAGER (BSM)
# -----------------------------------------------------------
# WebSocket port the BSM listens on for the upstream coordinator.
BSM_WS_PORT=4000
# Local TCP port the BSM uses to talk to the Bot Agents it spawns.
BSM_AGENT_PORT=4001
# Upstream coordinator WebSocket address (preferred).
# NOTE: ORCHESTRATOR_ADDRESS is a deprecated alias kept for backward compat —
# prefer COORDINATOR_ADDRESS.
COORDINATOR_ADDRESS=ws://localhost:5001
# World State Service HTTP API.
WORLD_STATE_API_ADDRESS=http://localhost:3000
# Stable BSM identifier (optional; auto-generated if unset).
# BSM_ID=bsm-01
# Path to the bot-agent entry the BSM forks (optional; defaults to ../bot-agent/dist/index.js).
# AGENT_SCRIPT_PATH=../bot-agent/dist/index.js


# -----------------------------------------------------------
# COORDINATOR
# -----------------------------------------------------------
# HTTP port.
COORDINATOR_PORT=5000
# WebSocket port for BSM and frontend connections.
COORDINATOR_WS_PORT=5001
# World State Service HTTP API.
WORLD_STATE_API_ADDRESS=http://localhost:3000


# -----------------------------------------------------------
# BOT AGENT
# -----------------------------------------------------------
# These are normally injected by the BSM when it spawns an agent — set manually
# only when running an agent standalone for debugging.
# Agent identifier.
# AGENT_ID=agent-xyz
# Host of the BSM the agent connects back to.
BSM_HOST=127.0.0.1
# TCP port of the BSM the agent connects back to.
BSM_TCP_PORT=4001


# =================================================================
# ADVANCED / OPTIONAL
# =================================================================
# Runtime mode: development | production
NODE_ENV=development
# Log verbosity: error | warn | info | debug
LOG_LEVEL=info

# =================================================================
# NOTES
# =================================================================
#
# Required variables:
#   - GEMINI_API_KEY (coordinator)
#   - MONGO_URI (world-state-service)
#   - MC_HOST / MC_PORT / MC_VERSION (agents)
#
# Startup order:
#   1. MongoDB
#   2. World State Service
#   3. Coordinator
#   4. Bot Server Manager(s)  (each spawns Bot Agents dynamically)
#
# For distributed deployment, replace localhost with the real service
# hostnames/IPs (or use the Docker service names, e.g. ws://coordinator:5001).
# =================================================================
